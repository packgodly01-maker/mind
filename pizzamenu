local player = game.Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- sounds
local CLICK_SOUND = "rbxassetid://138470560522298"
local START_SOUND = "rbxassetid://5732294340"

local wallTPEnabled = false
local wallBall = nil
local tpButton = nil

local savedPosition = nil
local savedMarker = nil

local function createPizzaGUI()

	if player.PlayerGui:FindFirstChild("PizzaGUI") then return end

	local gui = Instance.new("ScreenGui")
	gui.Name = "PizzaGUI"
	gui.ResetOnSpawn = false
	gui.Parent = player.PlayerGui

	-- sounds
	local clickSound = Instance.new("Sound",gui)
	clickSound.SoundId = CLICK_SOUND

	local startSound = Instance.new("Sound",gui)
	startSound.SoundId = START_SOUND
	startSound:Play()

	local function playClick()
		clickSound:Play()
	end

	-- notification
	local function notify(text,y)

		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(0,260,0,50)
		frame.Position = UDim2.new(1,300,0.25+y,0)
		frame.BackgroundColor3 = Color3.fromRGB(255,117,24)
		frame.Parent = gui

		Instance.new("UICorner",frame)

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,-10,1,-10)
		label.Position = UDim2.new(0,5,0,5)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.Font = Enum.Font.Fantasy
		label.TextColor3 = Color3.new(1,1,1)
		label.Text = text
		label.Parent = frame

		frame:TweenPosition(UDim2.new(1,-270,0.25+y,0),"Out","Quad",0.5,true)

		task.delay(4,function()
			frame:TweenPosition(UDim2.new(1,300,0.25+y,0),"In","Quad",0.5,true)
			task.wait(.5)
			frame:Destroy()
		end)

	end

	notify("THANK YOU for using Pizza Menu 🍕",0)
	task.wait(.4)
	notify("OWNERS: cmp4s , kolletkloudsyt",0.08)

	-- open button
	local open = Instance.new("ImageButton")
	open.Size = UDim2.new(0,60,0,60)
	open.Position = UDim2.new(0,20,1,-80)
	open.BackgroundTransparency = 1
	open.Image = "rbxassetid://5822600836"
	open.Parent = gui

	-- drag
	local dragging=false
	local dragStart,startPos

	open.InputBegan:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=true
			dragStart=input.Position
			startPos=open.Position
		end
	end)

	open.InputEnded:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=false
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
			local delta=input.Position-dragStart
			open.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
		end
	end)

	-- main frame
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0,240,0,320)
	frame.Position = UDim2.new(.5,-120,.5,-160)
	frame.BackgroundColor3 = Color3.fromRGB(255,117,24)
	frame.Visible=false
	frame.Active=true
	frame.Draggable=true
	frame.Parent=gui

	Instance.new("UICorner",frame)

	open.MouseButton1Click:Connect(function()
		playClick()
		frame.Visible=not frame.Visible
	end)

	local function makeButton(text,y)

		local b=Instance.new("TextButton")
		b.Size=UDim2.new(0,200,0,30)
		b.Position=UDim2.new(0,20,0,y)
		b.Text=text
		b.BackgroundColor3=Color3.fromRGB(255,200,120)
		b.TextScaled=true
		b.Parent=frame

		Instance.new("UICorner",b)

		b.MouseButton1Click:Connect(playClick)

		return b
	end

	local saveButton = makeButton("Save Pos",40)
	local tpButtonMain = makeButton("Teleport",80)
	local wallTPButton = makeButton("Wall TP",120)

	-- save pos
	saveButton.MouseButton1Click:Connect(function()

		local char=player.Character
		local root=char and char:FindFirstChild("HumanoidRootPart")

		if root then

			savedPosition=root.Position

			if savedMarker then savedMarker:Destroy() end

			savedMarker=Instance.new("Part")
			savedMarker.Shape=Enum.PartType.Ball
			savedMarker.Size=Vector3.new(2,2,2)
			savedMarker.Position=savedPosition
			savedMarker.Anchored=true
			savedMarker.CanCollide=false
			savedMarker.Material=Enum.Material.Neon
			savedMarker.Color=Color3.fromRGB(255,117,24)
			savedMarker.Parent=workspace

		end

	end)

	-- teleport
	tpButtonMain.MouseButton1Click:Connect(function()

		local char=player.Character
		local root=char and char:FindFirstChild("HumanoidRootPart")

		if root and savedPosition then
			root.CFrame=CFrame.new(savedPosition)
		end

	end)

	-- wall tp toggle
	wallTPButton.MouseButton1Click:Connect(function()

		wallTPEnabled=not wallTPEnabled

		if wallTPEnabled then

			wallBall=Instance.new("Part")
			wallBall.Shape=Enum.PartType.Ball
			wallBall.Size=Vector3.new(2,2,2)
			wallBall.Anchored=true
			wallBall.CanCollide=false
			wallBall.Material=Enum.Material.Neon
			wallBall.Color=Color3.fromRGB(255,117,24)
			wallBall.Parent=workspace

			tpButton=Instance.new("TextButton")
			tpButton.Size=UDim2.new(0,160,0,50)
			tpButton.Position=UDim2.new(.5,-80,.8,0)
			tpButton.Text="TP INSIDE"
			tpButton.TextScaled=true
			tpButton.BackgroundColor3=Color3.fromRGB(40,120,255)
			tpButton.Parent=gui

			Instance.new("UICorner",tpButton)

			tpButton.MouseButton1Click:Connect(function()

				local char=player.Character
				local root=char and char:FindFirstChild("HumanoidRootPart")

				if root and wallBall then
					root.CFrame=CFrame.new(wallBall.Position)
				end

			end)

		else

			if wallBall then wallBall:Destroy() wallBall=nil end
			if tpButton then tpButton:Destroy() tpButton=nil end

		end

	end)

	-- follow player
	RunService.RenderStepped:Connect(function()

		if wallTPEnabled and wallBall then

			local char=player.Character
			local root=char and char:FindFirstChild("HumanoidRootPart")

			if root then
				wallBall.Position=root.Position+(root.CFrame.LookVector*3)
			end

		end

	end)

end

createPizzaGUI()

player.CharacterAdded:Connect(function()
	task.wait(1)
	createPizzaGUI()
end)
