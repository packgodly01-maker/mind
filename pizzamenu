-- BUTTON CREATOR
local function createButton(text,y)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0,200,0,30)
	b.Position = UDim2.new(0,15,0,y)
	b.Text = text
	b.TextScaled = true
	b.BackgroundColor3 = Color3.fromRGB(255,200,120)
	b.Parent = mainFrame
	round(b)
	return b
end

local saveButton = createButton("Save Position",50)
local tpButton = createButton("Teleport",90)
local glideButton = createButton("Ragdoll Glide",130)
local recoverButton = createButton("Recover",170)
local autoGrabButton = createButton("Auto Grab: OFF",210)
local batAuraButton = createButton("Bat Aura: OFF",250)
local ragdollNoclipButton = createButton("Ragdoll Noclip: OFF",290)

-- SAVE POSITION
saveButton.MouseButton1Click:Connect(function()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		savedPosition = char.HumanoidRootPart.Position
	end
end)

-- TELEPORT
tpButton.MouseButton1Click:Connect(function()
	local char = player.Character
	if savedPosition and char and char:FindFirstChild("HumanoidRootPart") then
		char:MoveTo(savedPosition)
	end
end)

-- RAGDOLL GLIDE
glideButton.MouseButton1Click:Connect(function()

	local char = player.Character
	if not char then return end
	local humanoid = char:FindFirstChild("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")

	if humanoid and root and savedPosition then
		glideActive = true
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)

		task.spawn(function()
			while glideActive do
				local dir = (savedPosition-root.Position)
				if dir.Magnitude < 3 then
					glideActive = false
					humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
					break
				end
				root.Velocity = dir.Unit * 60
				task.wait()
			end
		end)
	end

end)

-- RECOVER
recoverButton.MouseButton1Click:Connect(function()

	local char = player.Character
	if not char then return end

	local humanoid = char:FindFirstChild("Humanoid")
	if humanoid then
		glideActive = false
		ragdollNoclipEnabled = false
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

end)

