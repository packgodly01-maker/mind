local function createPizzaGUI()

	if player.PlayerGui:FindFirstChild("PizzaGUI") then return end

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "PizzaGUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = player.PlayerGui

	-- CLICK SOUND OBJECT
	local clickSound = Instance.new("Sound")
	clickSound.SoundId = CLICK_SOUND
	clickSound.Volume = 1
	clickSound.Parent = screenGui

	local function playClick()
		clickSound:Play()
	end

	-- STARTUP SOUND
	local startSound = Instance.new("Sound")
	startSound.SoundId = START_SOUND
	startSound.Volume = 1
	startSound.Parent = screenGui
	startSound:Play()

	-- NOTIFICATION FUNCTION
	local function notify(text, delayY)

		local notif = Instance.new("Frame")
		notif.Size = UDim2.new(0,260,0,50)
		notif.Position = UDim2.new(1,300,0.2 + delayY,0)
		notif.BackgroundColor3 = Color3.fromRGB(255,117,24)
		notif.Parent = screenGui

		local corner = Instance.new("UICorner")
		corner.Parent = notif

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,-10,1,-10)
		label.Position = UDim2.new(0,5,0,5)
		label.BackgroundTransparency = 1
		label.TextColor3 = Color3.new(1,1,1)
		label.TextScaled = true
		label.Font = Enum.Font.Fantasy
		label.Text = text
		label.Parent = notif

		notif:TweenPosition(UDim2.new(1,-270,0.2 + delayY,0),"Out","Quad",0.6,true)

		task.delay(4,function()
			notif:TweenPosition(UDim2.new(1,300,0.2 + delayY,0),"In","Quad",0.6,true)
			task.wait(0.6)
			notif:Destroy()
		end)

	end

	-- SHOW NOTIFICATIONS
	notify("THANK YOU for using Pizza Menu 🍕",0)
	task.wait(0.5)
	notify("OWNERS: cmp4s , kolletkloudsyt",0.08)

	-- OPEN BUTTON
	local openButton = Instance.new("ImageButton")
	openButton.Size = UDim2.new(0,60,0,60)
	openButton.Position = UDim2.new(0,20,1,-80)
	openButton.BackgroundTransparency = 1
	openButton.Image = "https://www.roblox.com/asset-thumbnail/image?assetId=5822600836&width=420&height=420&format=png"
	openButton.Parent = screenGui

	-- DRAG SYSTEM
	local dragging = false
	local dragStart
	local startPos

	openButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = openButton.Position
		end
	end)

	openButton.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			openButton.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)

	-- MAIN FRAME
	local mainFrame = Instance.new("Frame")
	mainFrame.Size = UDim2.new(0,240,0,320)
	mainFrame.Position = UDim2.new(0.5,-120,0.5,-160)
	mainFrame.BackgroundColor3 = Color3.fromRGB(255,117,24)
	mainFrame.Visible = false
	mainFrame.Active = true
	mainFrame.Draggable = true
	mainFrame.Parent = screenGui

	local corner = Instance.new("UICorner",mainFrame)
	corner.CornerRadius = UDim.new(0,12)

	openButton.MouseButton1Click:Connect(function()
		playClick()
		mainFrame.Visible = not mainFrame.Visible
	end)

	local function roundButton(btn)
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0,8)
		c.Parent = btn

		btn.MouseButton1Click:Connect(playClick)
