local player = game.Players.LocalPlayer
local glideLoop = nil
local autoGrabEnabled = false
local batAuraEnabled = false
local auraRadius = 10
local ragdollNoclipEnabled = false
local savedMarker = nil

local wallTPEnabled = false
local wallBall = nil
local tpButton = nil

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local function createPizzaGUI()

	if player.PlayerGui:FindFirstChild("PizzaGUI") then return end

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "PizzaGUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = player.PlayerGui

	-- OPEN BUTTON
	local openButton = Instance.new("ImageButton")
	openButton.Size = UDim2.new(0,60,0,60)
	openButton.Position = UDim2.new(0,20,1,-80)
	openButton.BackgroundTransparency = 1
	openButton.Image = "https://www.roblox.com/asset-thumbnail/image?assetId=5822600836&width=420&height=420&format=png"
	openButton.Parent = screenGui

	-- MAIN FRAME
	local mainFrame = Instance.new("Frame")
	mainFrame.Size = UDim2.new(0,240,0,320)
	mainFrame.Position = UDim2.new(0.5,-120,0.5,-160)
	mainFrame.BackgroundColor3 = Color3.fromRGB(255,117,24)
	mainFrame.Visible = false
	mainFrame.Active = true
	mainFrame.Draggable = true
	mainFrame.Parent = screenGui

	local corner = Instance.new("UICorner",mainFrame)
	corner.CornerRadius = UDim.new(0,12)

	openButton.MouseButton1Click:Connect(function()
		mainFrame.Visible = not mainFrame.Visible
	end)

	local function roundButton(btn)
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0,8)
		c.Parent = btn
	end

	-- TITLE
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1,0,0,25)
	title.BackgroundTransparency = 1
	title.Text = "PIZZA GUI"
	title.TextColor3 = Color3.fromRGB(255,165,0)
	title.TextScaled = true
	title.Font = Enum.Font.Fantasy
	title.Parent = mainFrame

	-- TAB BUTTONS
	local mainTab = Instance.new("TextButton")
	mainTab.Size = UDim2.new(0.5,0,0,25)
	mainTab.Position = UDim2.new(0,0,0,25)
	mainTab.Text = "Main Mods"
	mainTab.Parent = mainFrame

	local coolTab = Instance.new("TextButton")
	coolTab.Size = UDim2.new(0.5,0,0,25)
	coolTab.Position = UDim2.new(0.5,0,0,25)
	coolTab.Text = "Cool Stuff"
	coolTab.Parent = mainFrame

	roundButton(mainTab)
	roundButton(coolTab)

	-- PAGES
	local mainPage = Instance.new("Frame")
	mainPage.Size = UDim2.new(1,0,1,-50)
	mainPage.Position = UDim2.new(0,0,0,50)
	mainPage.BackgroundTransparency = 1
	mainPage.Parent = mainFrame

	local coolPage = Instance.new("Frame")
	coolPage.Size = UDim2.new(1,0,1,-50)
	coolPage.Position = UDim2.new(0,0,0,50)
	coolPage.BackgroundTransparency = 1
	coolPage.Visible = false
	coolPage.Parent = mainFrame

	mainTab.MouseButton1Click:Connect(function()
		mainPage.Visible = true
		coolPage.Visible = false
	end)

	coolTab.MouseButton1Click:Connect(function()
		mainPage.Visible = false
		coolPage.Visible = true
	end)

	-- BUTTON MAKER
	local function makeButton(text,y,parent)
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(0,200,0,30)
		b.Position = UDim2.new(0,20,0,y)
		b.Text = text
		b.BackgroundColor3 = Color3.fromRGB(255,200,120)
		b.TextScaled = true
		b.Parent = parent
		roundButton(b)
		return b
	end

	local savedPosition=nil

	local saveButton = makeButton("Save Pos",10,mainPage)
	local tpButton = makeButton("Teleport",50,mainPage)
	local ragdollGlideButton = makeButton("Ragdoll Glide",90,mainPage)
	local autoGrabButton = makeButton("Auto Grab: OFF",130,mainPage)
	local batAuraButton = makeButton("Bat Aura: OFF",170,mainPage)
	local ragdollNoclipButton = makeButton("Ragdoll Noclip: OFF",210,mainPage)

	local wallTPButton = makeButton("Wall TP",10,coolPage)

	-- SAVE POS + MARKER
	saveButton.MouseButton1Click:Connect(function()

		local char=player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then

			savedPosition=char.HumanoidRootPart.Position

			if savedMarker then
				savedMarker:Destroy()
			end

			savedMarker=Instance.new("Part")
			savedMarker.Shape=Enum.PartType.Ball
			savedMarker.Size=Vector3.new(2,2,2)
			savedMarker.Position=savedPosition
			savedMarker.Anchored=true
			savedMarker.CanCollide=false
			savedMarker.Color=Color3.fromRGB(255,117,24)
			savedMarker.Material=Enum.Material.Neon
			savedMarker.Parent=workspace

		end

	end)

	-- TELEPORT
	tpButton.MouseButton1Click:Connect(function()
		local char=player.Character
		if savedPosition and char then
			char:MoveTo(savedPosition)
		end
	end)

	-- AUTO GRAB
	autoGrabButton.MouseButton1Click:Connect(function()
		autoGrabEnabled=not autoGrabEnabled
		autoGrabButton.Text=autoGrabEnabled and "Auto Grab: ON" or "Auto Grab: OFF"
	end)

	-- BAT AURA
	batAuraButton.MouseButton1Click:Connect(function()
		batAuraEnabled=not batAuraEnabled
		batAuraButton.Text=batAuraEnabled and "Bat Aura: ON" or "Bat Aura: OFF"
	end)

	-- RAGDOLL NOCLIP
	ragdollNoclipButton.MouseButton1Click:Connect(function()

		ragdollNoclipEnabled=not ragdollNoclipEnabled
		local char=player.Character
		if char then
			local humanoid=char:FindFirstChild("Humanoid")

			if ragdollNoclipEnabled then
				ragdollNoclipButton.Text="Ragdoll Noclip: ON"
				if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Physics) end
			else
				ragdollNoclipButton.Text="Ragdoll Noclip: OFF"
				if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
			end

		end

	end)

	-- WALL TP
	wallTPButton.MouseButton1Click:Connect(function()

		wallTPEnabled=not wallTPEnabled

		if wallTPEnabled then

			local char=player.Character
			local root=char and char:FindFirstChild("HumanoidRootPart")

			if root then

				wallBall=Instance.new("Part")
				wallBall.Shape=Enum.PartType.Ball
				wallBall.Size=Vector3.new(2,2,2)
				wallBall.Color=Color3.fromRGB(255,117,24)
				wallBall.Material=Enum.Material.Neon
				wallBall.Anchored=true
				wallBall.CanCollide=false
				wallBall.Position=root.Position+root.CFrame.LookVector*10
				wallBall.Parent=workspace

				tpButton=Instance.new("TextButton")
				tpButton.Text="TP INSIDE"
				tpButton.Size=UDim2.new(0,160,0,50)
				tpButton.Position=UDim2.new(0.5,-80,0.8,0)
				tpButton.BackgroundColor3=Color3.fromRGB(40,120,255)
				tpButton.TextScaled=true
				tpButton.Parent=screenGui
				roundButton(tpButton)

				tpButton.MouseButton1Click:Connect(function()
					local char=player.Character
					local root=char and char:FindFirstChild("HumanoidRootPart")
					if root and wallBall then
						root.CFrame=CFrame.new(wallBall.Position)
					end
				end)

			end

		else

			if wallBall then wallBall:Destroy() wallBall=nil end
			if tpButton then tpButton:Destroy() tpButton=nil end

		end

	end)

	RunService.Heartbeat:Connect(function()

		local char=player.Character
		if not char then return end

		local root=char:FindFirstChild("HumanoidRootPart")
		local humanoid=char:FindFirstChild("Humanoid")
		if not root or not humanoid then return end

		if ragdollNoclipEnabled then

			if humanoid:GetState()~=Enum.HumanoidStateType.Physics then
				humanoid:ChangeState(Enum.HumanoidStateType.Physics)
			end

			for _,part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide=false end
			end

			local cam=workspace.CurrentCamera
			local moveDir=Vector3.zero

			if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir+=cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir-=cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir-=cam.CFrame.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir+=cam.CFrame.RightVector end

			moveDir=Vector3.new(moveDir.X,0,moveDir.Z)

			if moveDir.Magnitude>0 then
				root.Velocity=root.Velocity:Lerp(moveDir.Unit*45,0.25)
			end

		end

	end)

end

createPizzaGUI()
player.CharacterAdded:Connect(function()
	task.wait(1)
	createPizzaGUI()
end)
