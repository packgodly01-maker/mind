-- store original Motor6Ds for recovery
local originalMotors = {}

local function storeMotors(character)
	originalMotors = {}
	for _, motor in pairs(character:GetDescendants()) do
		if motor:IsA("Motor6D") then
			table.insert(originalMotors, motor:Clone())
		end
	end
end

-- ragdoll + glide toward saved position
local function ragdollGlide(character)
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid then return end
	storeMotors(character)
	humanoid:ChangeState(Enum.HumanoidStateType.Physics)

	for _, motor in pairs(character:GetDescendants()) do
		if motor:IsA("Motor6D") then
			local a0 = Instance.new("Attachment")
			local a1 = Instance.new("Attachment")
			a0.Parent = motor.Part0
			a1.Parent = motor.Part1
			a0.CFrame = motor.C0
			a1.CFrame = motor.C1
			local socket = Instance.new("BallSocketConstraint")
			socket.Attachment0 = a0
			socket.Attachment1 = a1
			socket.Parent = motor.Parent
			motor:Destroy()
		end
	end

	if savedPosition then
		spawn(function()
			while humanoid.Parent do
				local root = character:FindFirstChild("HumanoidRootPart")
				if root then
					local dir = (savedPosition - root.Position)
					if dir.Magnitude < 1 then break end
					root.Velocity = dir.Unit * 50
				end
				task.wait(0.05)
			end
		end)
	end
end

-- recover function
local function recover(character)
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid then return end
	-- destroy any attachments from ragdoll
	for _, att in pairs(character:GetDescendants()) do
		if att:IsA("Attachment") or att:IsA("BallSocketConstraint") then
			att:Destroy()
		end
	end
	-- restore motors
	for _, motor in pairs(originalMotors) do
		if motor.Parent and motor.Parent:IsDescendantOf(character) then
			motor.Parent = motor.Parent
		else
			motor.Parent = character:FindFirstChild(motor.Part0.Name)
		end
	end
	humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
end

-- button triggers
ragdollButton.MouseButton1Click:Connect(function()
	local char = player.Character
	if char then
		ragdollGlide(char)
	end
end)

recoverButton.MouseButton1Click:Connect(function()
	local char = player.Character
	if char then
		recover(char)
	end
end)
