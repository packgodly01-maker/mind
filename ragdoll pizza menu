-- ragdoll + glide to saved position
local function ragdollGlide(character)
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid then return end
	humanoid:ChangeState(Enum.HumanoidStateType.Physics)

	for _, motor in pairs(character:GetDescendants()) do
		if motor:IsA("Motor6D") then
			local a0 = Instance.new("Attachment")
			local a1 = Instance.new("Attachment")

			a0.Parent = motor.Part0
			a1.Parent = motor.Part1

			a0.CFrame = motor.C0
			a1.CFrame = motor.C1

			local socket = Instance.new("BallSocketConstraint")
			socket.Attachment0 = a0
			socket.Attachment1 = a1
			socket.Parent = motor.Parent

			motor:Destroy()
		end
	end

	-- glide toward saved position
	if savedPosition then
		spawn(function()
			while humanoid.Parent do
				local root = character:FindFirstChild("HumanoidRootPart")
				if root then
					local direction = (savedPosition - root.Position)
					local distance = direction.Magnitude
					if distance < 1 then break end
					root.Velocity = direction.Unit * 50 -- speed, adjust as needed
				end
				task.wait(0.05)
			end
		end)
	end
end

-- button trigger
ragdollButton.MouseButton1Click:Connect(function()
	local char = player.Character
	if char then
		ragdollGlide(char)
	end
end)
